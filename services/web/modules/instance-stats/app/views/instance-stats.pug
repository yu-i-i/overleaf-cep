extends ../../../../app/views/layout-marketing

include ../../../../app/views/_mixins/bookmarkable_tabset.pug

block entrypointVar
	- entrypoint = 'modules/instance-stats/pages/instance-stats'

block content
	#main-content.content.content-alt
		.container
			.row
				.col-sm-12
					.card#instance-stats-root
						.card-body
							.page-header
								h1 Instance statistics

							.row.justify-content-end
								.col-2
									label.form-label(for='timeFilter') Show:
									select#timeFilter.form-select
										option(value='month' selected) Last 1 month
										option(value='6m') Last 6 months
										option(value='year') Last 1 year
										option(value='all') All

							hr

							// Charts (organized into tabs)
							ol-tabs.ol-tabs(data-ol-bookmarkable-tabset)
								.nav-tabs-container
									ul.nav.nav-tabs.align-left(role='tablist')
										+bookmarkable-tabset-header('user', 'User', true)
										+bookmarkable-tabset-header('project', 'Project')
										+bookmarkable-tabset-header('storage', 'Storage')

								.tab-content
									.tab-pane.active(role='tabpanel' id='user')
										.row(style='height:400px')
											.col-md-6#active-users
											.col-md-6#user-count

									.tab-pane(role='tabpanel' id='project')
										.row(style='height:400px')
											.col-md-4#active-projects
											.col-md-4#project-count
											.col-md-4#file-count

									.tab-pane(role='tabpanel' id='storage')
										.row(style='height:400px')
											.col-md-4#mongodb-storage
											.col-md-4#overleaf-storage
											.col-md-4#redis-storage

block prepend foot-scripts
	script(src='https://cdn.plot.ly/plotly-3.0.1.min.js' charset='utf-8' nonce=scriptNonce defer=deferScripts)

