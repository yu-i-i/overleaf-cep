extends ../layout-website-redesign

block vars
	- isWebsiteRedesign = true
	- var localLoginEnabled = (ssoLoginPage && ssoLoginPage.localLoginEnabled !== undefined) ? ssoLoginPage.localLoginEnabled : true
	- var ldapActive = ssoLdapEnabled || (settings.ldap && settings.ldap.enable)
	- var ldapPlaceholder = ssoLdapPlaceholder || (settings.ldap && settings.ldap.placeholder) || 'Username'
	- var loginLogo = ssoLoginPage && ssoLoginPage.logoUrl
	- var loginLogoWidth = (ssoLoginPage && ssoLoginPage.logoWidth) || '200px'
	- var loginTitle = ssoLoginPage && ssoLoginPage.title

block content
	main#main-content.content
		.container
			.row
				.col-lg-6.offset-lg-3.col-xl-4.offset-xl-4
					if loginLogo
						.text-center.mb-3
							img(src=loginLogo style=`width: ${loginLogoWidth}; max-width: 100%;`)
					.page-header
						if loginTitle
							h1 !{loginTitle}
						else if login_support_title
							h1 !{login_support_title}
						else
							h1 #{translate("log_in")} 
					if localLoginEnabled
						form(name='loginForm' data-ol-async-form action='/login' method='POST')
							input(name='_csrf' type='hidden' value=csrfToken)
							+formMessagesNewStyle
							+customFormMessageNewStyle('invalid-password-retry-or-reset', 'danger')
								| !{translate('email_or_password_wrong_try_again_or_reset', {}, [{ name: 'a', attrs: { href: '/user/password/reset', 'aria-describedby': 'resetPasswordDescription' } }])}
								span.visually-hidden(id='resetPasswordDescription')
									| #{translate('reset_password_link')}
							+customFormMessageNewStyle('password-compromised')
								| !{translate('password_compromised_try_again_or_use_known_device_or_reset', {}, [{name: 'a', attrs: {href: 'https://haveibeenpwned.com/passwords', rel: 'noopener noreferrer', target: '_blank'}}, {name: 'a', attrs: {href: '/user/password/reset', target: '_blank'}}])}.
							.form-group
								label(for='email') #{translate("email")}
								input#email.form-control(
									name='email'
									type=ldapActive ? 'text' : 'email'
									required
									placeholder=ldapActive ? ldapPlaceholder : 'email@example.com'
									autofocus='true'
									autocomplete='username'
								)
							.form-group
								label(for='password') #{translate("password")}
								input#password.form-control(
									name='password'
									type='password'
									autocomplete='current-password'
									required
								)
							.actions
								button.btn-primary.btn(type='submit' data-ol-disabled-inflight)
									span(data-ol-inflight='idle') #{translate("login")}
									span(hidden data-ol-inflight='pending') #{translate("logging_in")}…
								a.float-end(href='/user/password/reset') #{translate("forgot_your_password")}?
							if login_support_text
								hr
								p.text-center !{login_support_text}
					//- Dynamic SSO providers from database
					if ssoProviders && ssoProviders.length
						each provider in ssoProviders
							.actions(style='margin-top: 20px;')
								a.button.btn-secondary.btn(
									href=provider.loginUrl,
									style="width: 100%;"
									data-ol-disabled-inflight
								)
									span(data-ol-inflight="idle") #{provider.buttonLabel}
									span(hidden data-ol-inflight="pending") #{translate("logging_in")}…
					else
						//- Fallback to settings-based providers (env var mode)
						if settings.saml && settings.saml.enable
							.actions(style='margin-top: 20px;')
								a.button.btn-secondary.btn(
								href='/saml/login',
									style="width: 100%;"
									data-ol-disabled-inflight
								)
									span(data-ol-inflight="idle") #{settings.saml.identityServiceName}
									span(hidden data-ol-inflight="pending") #{translate("logging_in")}…
						if settings.oidc && settings.oidc.enable
							.actions(style='margin-top: 20px;')
								a.button.btn-secondary.btn(
									href='/oidc/login',
									style="width: 100%;"
									data-ol-disabled-inflight
								)
									span(data-ol-inflight="idle") #{settings.oidc.identityServiceName}
									span(hidden data-ol-inflight="pending") #{translate("logging_in")}…
					if !localLoginEnabled && (!ssoProviders || !ssoProviders.length) && !(settings.saml && settings.saml.enable) && !(settings.oidc && settings.oidc.enable)
						.alert.alert-warning.mt-3
							| No login methods are currently configured. Please contact your administrator.
